# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres

# Server
PORT=8080

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:3000

# Authentication
JWT_SECRET=super_secret_jwt_key_please_change_in_production

# Google OAuth 2.0 Credentials
# Get these from: https://console.cloud.google.com/apis/credentials
# 1. Create OAuth 2.0 Client ID
# 2. Add authorized JavaScript origins: http://localhost:3000
# 3. Add authorized redirect URI: http://localhost:8080/api/auth/google/callback
# 4. Copy Client ID and Client Secret here
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE
GOOGLE_CALLBACK_URL=http://localhost:8080/api/auth/google/callback

# Email Verification (Nodemailer - Gmail SMTP)
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
